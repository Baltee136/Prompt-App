rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Anyone can read prompts (no account needed).
    // Only the Firebase Console / Admin SDK (which bypasses these rules)
    // or an authenticated admin can write.
    match /prompts/{promptId} {
      allow read: if true;
      allow write: if false; // tighten/replace with admin auth check if needed
    }
  }
}
